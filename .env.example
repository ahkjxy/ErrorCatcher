# ErrorCatcher Docker Compose 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ==================== 环境配置 ====================
# 运行环境: development | production
NODE_ENV=production

# ==================== MongoDB 配置 ====================
# MongoDB root 用户密码（首次启动时设置）
MONGO_ROOT_PASSWORD=your-strong-root-password

# 应用数据库用户密码
DB_PASSWORD=your-strong-db-password

# ==================== JWT 配置 ====================
# JWT 签名密钥（必须修改，至少 32 字符）
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# JWT 过期时间（7d=7天, 24h=24小时, 30m=30分钟）
JWT_EXPIRES_IN=7d

# ==================== CORS 配置 ====================
# 允许跨域访问的源（多个用逗号分隔）
# 开发环境: *
# 生产环境: https://your-domain.com,https://www.your-domain.com
CORS_ORIGIN=*

# ==================== 日志配置 ====================
# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# ==================== 前端配置 ====================
# API 服务器地址 (开发环境使用localhost，生产/局域网环境请使用实际IP地址，如 http://192.168.1.100:3001)
VITE_API_URL=http://localhost:3001

# WebSocket 服务器地址 (开发环境使用localhost，生产/局域网环境请使用实际IP地址，如 http://192.168.1.100:3001)
VITE_WS_URL=http://localhost:3001

# ==================== 钉钉通知配置（可选）====================
# 钉钉机器人 Webhook 地址
DINGTALK_WEBHOOK=

# 钉钉机器人签名密钥
DINGTALK_SECRET=
