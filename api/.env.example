# 环境配置示例
# 复制此文件为 .env.{环境名} 并修改相应配置

# 环境: dev | test | pre | prod
NODE_ENV=dev

# 服务端口
PORT=3001

# MongoDB 连接字符串
# 开发环境: mongodb://localhost:27017/error-catcher-dev
# 测试环境: mongodb://localhost:27017/error-catcher-test
# 预发布环境: mongodb://pre-server:27017/error-catcher-pre
# 生产环境: mongodb://prod-server:27017/error-catcher
MONGODB_URI=mongodb://localhost:27017/error-catcher-dev

# CORS 允许的源（多个用逗号分隔）
# 开发环境: http://localhost:3000,http://localhost:5173
# 测试环境: http://test.example.com
# 预发布环境: https://pre.example.com
# 生产环境: https://example.com,https://www.example.com
CORS_ORIGIN=*

# 日志级别: debug | info | warn | error
LOG_LEVEL=debug

# JWT 密钥（生产环境必须修改）
JWT_SECRET=your-secret-key-change-in-production

# OpenAI API 配置（用于 AI 错误分析功能）
# 获取 API Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini
