{
  "name": "error-catcher-api",
  "version": "1.0.0",
  "description": "Error Catcher API Server with MongoDB",
  "main": "src/index.js",
  "scripts": {
    "dev": "NODE_ENV=dev nodemon src/index.js",
    "test": "NODE_ENV=test nodemon src/index.js",
    "pre": "NODE_ENV=pre node src/index.js",
    "prod": "NODE_ENV=prod node src/index.js",
    "start": "node src/index.js",
    "start:dev": "node -r dotenv/config src/index.js dotenv_config_path=.env.dev",
    "start:test": "node -r dotenv/config src/index.js dotenv_config_path=.env.test",
    "start:pre": "node -r dotenv/config src/index.js dotenv_config_path=.env.pre",
    "start:prod": "node -r dotenv/config src/index.js dotenv_config_path=.env.prod",
    "seed": "node scripts/seed-data.js",
    "seed:dev": "NODE_ENV=dev node scripts/seed-data.js",
    "seed:test": "NODE_ENV=test node scripts/seed-data.js",
    "seed:all": "node scripts/seed-all-data.js",
    "seed:all:dev": "NODE_ENV=dev node scripts/seed-all-data.js",
    "test:dingtalk": "node scripts/test-dingtalk.js",
    "clear": "node scripts/clear-data.js",
    "clear:dev": "NODE_ENV=dev node scripts/clear-data.js",
    "create-admin": "node scripts/create-admin.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "nodemailer": "^8.0.1",
    "rate-limit-redis": "^4.1.5",
    "redis": "^4.6.12",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
